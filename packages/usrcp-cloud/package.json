{
  "name": "usrcp-cloud",
  "version": "0.0.1",
  "description": "Hosted ledger for USRCP — ciphertext-only cross-device sync",
  "main": "dist/index.js",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "bin": {
    "usrcp-cloud": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "usrcp",
    "hosted-ledger",
    "sync",
    "ciphertext"
  ],
  "author": "USRCP Contributors",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "fastify": "5.2.1",
    "pg": "8.13.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "@types/pg": "8.11.10",
    "pg-mem": "3.0.3",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  }
}
