{
  "name": "usrcp-local",
  "version": "0.1.0",
  "description": "Local MCP server for USRCP — persistent AI memory on your machine",
  "main": "dist/index.js",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "bin": {
    "usrcp-local": "dist/index.js",
    "usrcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js serve",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "usrcp",
    "mcp",
    "ai-memory",
    "context-protocol",
    "llm",
    "agent"
  ],
  "author": "USRCP Contributors",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "11.10.0",
    "selfsigned": "^5.5.0",
    "yaml": "^2.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.19.17",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  }
}
