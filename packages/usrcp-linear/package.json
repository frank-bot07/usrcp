{
  "name": "usrcp-linear",
  "version": "0.0.1",
  "description": "Linear capture adapter for USRCP — polls Linear's GraphQL API for issues and comments authored by the configured user, and appends them to the local ledger",
  "main": "dist/index.js",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "bin": {
    "usrcp-linear": "dist/index.js"
  },
  "scripts": {
    "prebuild": "cd ../usrcp-local && npm run build",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "pretest": "cd ../usrcp-local && npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "usrcp",
    "linear",
    "adapter",
    "memory",
    "issue-tracker"
  ],
  "author": "USRCP Contributors",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@linear/sdk": "^39.1.0",
    "usrcp-local": "file:../usrcp-local"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "22.19.17",
    "better-sqlite3": "*",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  }
}
